---
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";

const painCards = [
  {
    title: "Manual escalation is slow",
    desc: "Teams rely on calls and texts that are hard to track and easy to miss.",
    icon: "clock",
  },
  {
    title: "Managers get pulled into routine issues",
    desc: "Routine overnight problems still interrupt senior staff and coordinators.",
    icon: "alert",
  },
  {
    title: "There is no live visibility",
    desc: "It is hard to know what is happening in real time overnight.",
    icon: "eye-off",
  },
  {
    title: "Morning handover is messy",
    desc: "Important details can be lost across calls, messages, and memory.",
    icon: "file-x",
  },
];
---

<Section padding="lg">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        After-hours should not run on missed calls, text chains, and guesswork
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        Many providers still manage after-hours through personal phones, manual call trees, and fragmented handovers. That creates slow response times, staff fatigue, poor overnight visibility, and messy reporting by morning.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {painCards.map((card) => (
        <div class="group rounded-xl border border-border/60 bg-card p-6 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            {card.icon === "clock" && (
              <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            )}
            {card.icon === "alert" && (
              <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path>
              </svg>
            )}
            {card.icon === "eye-off" && (
              <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"></path><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"></path><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"></path><line x1="2" x2="22" y1="2" y2="22"></line>
              </svg>
            )}
            {card.icon === "file-x" && (
              <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="m14.5 12.5-5 5"></path><path d="m9.5 12.5 5 5"></path>
              </svg>
            )}
          </div>
          <h3 class="mt-4 text-sm font-semibold text-foreground">{card.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{card.desc}</p>
        </div>
      ))}
    </div>
  </Container>
</Section>
