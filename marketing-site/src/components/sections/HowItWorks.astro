---
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";
import HeroProductMock from "./HeroProductMock.astro";

const steps = [
  { icon: "building", label: "Set up" },
  { icon: "settings", label: "Configure" },
  { icon: "calendar", label: "Upload roster" },
  { icon: "zap", label: "Run overnight" },
  { icon: "file-check", label: "Morning report" },
];
---

<Section id="how-it-works" padding="lg" class="bg-muted/20">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">
        How it works
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        From setup to morning report in five steps
      </h2>
    </div>

    {/* ─── Horizontal step diagram ─── */}
    <div class="mt-12 overflow-x-auto">
      <div class="mx-auto flex min-w-[540px] max-w-3xl items-start justify-between">
        {steps.map((step, i) => (
          <div class="flex flex-col items-center" style={`flex: 0 0 ${100 / steps.length}%`}>
            {/* Node row with connector lines */}
            <div class="relative flex w-full items-center justify-center">
              {/* Left connector */}
              {i > 0 && (
                <div class="absolute right-1/2 top-1/2 h-[2px] w-full -translate-y-1/2 bg-border/60" />
              )}
              {/* Right connector */}
              {i < steps.length - 1 && (
                <div class="absolute left-1/2 top-1/2 h-[2px] w-full -translate-y-1/2 bg-border/60" />
              )}
              {/* Icon circle */}
              <div class="relative z-10 flex h-12 w-12 items-center justify-center rounded-full border-2 border-primary/20 bg-card shadow-sm">
                {step.icon === "building" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="16" height="20" x="4" y="2" rx="2" ry="2"></rect>
                    <path d="M9 22v-4h6v4"></path><path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path><path d="M12 10h.01"></path><path d="M12 14h.01"></path><path d="M16 10h.01"></path><path d="M16 14h.01"></path><path d="M8 10h.01"></path><path d="M8 14h.01"></path>
                  </svg>
                )}
                {step.icon === "settings" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle>
                  </svg>
                )}
                {step.icon === "calendar" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path>
                  </svg>
                )}
                {step.icon === "zap" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
                  </svg>
                )}
                {step.icon === "file-check" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="m9 15 2 2 4-4"></path>
                  </svg>
                )}
              </div>
            </div>
            {/* Label */}
            <span class="mt-3 text-center text-xs font-medium text-muted-foreground">{step.label}</span>
          </div>
        ))}
      </div>
    </div>

    {/* ─── Large product mockup ─── */}
    <div class="relative mt-12">
      <div class="pointer-events-none absolute -right-20 top-8 h-[350px] w-[350px] rounded-full bg-primary/[0.04] blur-[80px]" aria-hidden="true"></div>
      <div class="relative">
        <HeroProductMock />
      </div>
    </div>

    <div class="mt-8 text-center">
      <a
        href="/how-it-works"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline"
      >
        See the full walkthrough <span>&rarr;</span>
      </a>
    </div>
  </Container>
</Section>
