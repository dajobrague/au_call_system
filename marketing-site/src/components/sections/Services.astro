---
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";

interface Service {
  title: string;
  icon: string;
  desc: string;
  bullets: [string, string];
  primary: boolean;
}

const services: Service[] = [
  {
    title: "After-Hours Call Handling",
    icon: "phone-call",
    desc: "Professional call answering, triage, and routing for after-hours staff enquiries.",
    bullets: ["Live call answering and triage", "Structured message capture"],
    primary: true,
  },
  {
    title: "Roster Management",
    icon: "calendar-clock",
    desc: "Shift coverage coordination and last-minute roster gap resolution.",
    bullets: ["On-call schedule visibility", "Gap detection and fill workflows"],
    primary: true,
  },
  {
    title: "Incident Response",
    icon: "shield-alert",
    desc: "Defined escalation pathways for critical incidents and safety events.",
    bullets: ["Severity-based escalation tiers", "Real-time stakeholder alerts"],
    primary: false,
  },
  {
    title: "PRN Medication Authorisation",
    icon: "clipboard-check",
    desc: "Time-sensitive medication approval workflows with full audit trails.",
    bullets: ["Verbal authorisation capture", "Compliance-ready documentation"],
    primary: false,
  },
  {
    title: "Complaint Resolution",
    icon: "message-square-warning",
    desc: "Structured de-escalation, documentation, and follow-up capture.",
    bullets: ["Caller de-escalation protocols", "Documented resolution tracking"],
    primary: false,
  },
  {
    title: "Support Changes",
    icon: "refresh-cw",
    desc: "Urgent care plan updates and last-minute support adjustments.",
    bullets: ["Rapid plan amendment workflows", "Stakeholder notification chain"],
    primary: false,
  },
  {
    title: "Positive Behaviour Support",
    icon: "users",
    desc: "Specialized guidance pathways during behavioural events.",
    bullets: ["Behaviour-specific protocols", "Guided staff de-briefing"],
    primary: false,
  },
  {
    title: "24/7 Coverage & Continuity",
    icon: "clock",
    desc: "Continuous coverage assurance with handover notes and shift continuity.",
    bullets: ["Seamless shift handover logs", "After-hours continuity reporting"],
    primary: false,
  },
];
---

<Section id="services" padding="lg">
  <Container>
    {/* Section header */}
    <div class="max-w-2xl space-y-3">
      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">
        Our Services
      </p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Tailored after-hours support for NDIS providers
      </h2>
      <p class="text-base leading-relaxed text-muted-foreground">
        At On Call After Hours, we provide tailored after-hours solutions for NDIS service providers. From managing urgent calls to resolving client concerns, our services ensure your business and clients are supported 24/7 with professionalism and care.
      </p>
    </div>

    {/* Bento grid */}
    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-12">
      {services.map((svc) => (
        <div
          class:list={[
            "group flex flex-col rounded-xl border border-border/60 bg-card shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md focus-within:-translate-y-0.5 focus-within:shadow-md",
            svc.primary ? "relative overflow-hidden p-6 lg:col-span-6" : "p-5 lg:col-span-4",
          ]}
        >
          {/* Subtle accent blob on primary cards */}
          {svc.primary && (
            <div
              class="pointer-events-none absolute -right-16 -top-16 h-[200px] w-[200px] rounded-full bg-primary/[0.05] blur-[60px]"
              aria-hidden="true"
            ></div>
          )}
          {/* Top row: icon + title */}
          <div class="flex items-start gap-3">
            <div
              class:list={[
                "flex shrink-0 items-center justify-center rounded-full bg-primary/10",
                svc.primary ? "h-11 w-11" : "h-10 w-10",
              ]}
            >
                {/* PhoneCall */}
                {svc.icon === "phone-call" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                    <path d="M14.05 2a9 9 0 0 1 8 7.94"></path>
                    <path d="M14.05 6A5 5 0 0 1 18 10"></path>
                  </svg>
                )}
                {/* CalendarClock */}
                {svc.icon === "calendar-clock" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 7.5V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h3.5"></path>
                    <path d="M16 2v4"></path>
                    <path d="M8 2v4"></path>
                    <path d="M3 10h5"></path>
                    <circle cx="16" cy="16" r="6"></circle>
                    <path d="M16 14v2l1 1"></path>
                  </svg>
                )}
                {/* ShieldAlert */}
                {svc.icon === "shield-alert" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                    <path d="M12 8v4"></path>
                    <path d="M12 16h.01"></path>
                  </svg>
                )}
                {/* ClipboardCheck */}
                {svc.icon === "clipboard-check" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1"></rect>
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path>
                    <path d="m9 14 2 2 4-4"></path>
                  </svg>
                )}
                {/* MessageSquareWarning */}
                {svc.icon === "message-square-warning" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                    <path d="M12 7v2"></path>
                    <path d="M12 13h.01"></path>
                  </svg>
                )}
                {/* RefreshCw */}
                {svc.icon === "refresh-cw" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
                    <path d="M21 3v5h-5"></path>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"></path>
                    <path d="M3 21v-5h5"></path>
                  </svg>
                )}
                {/* Users */}
                {svc.icon === "users" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                  </svg>
                )}
                {/* Clock */}
                {svc.icon === "clock" && (
                  <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                  </svg>
                )}
              </div>
            <h3 class:list={["font-semibold text-foreground", svc.primary ? "text-lg" : "text-base"]}>
              {svc.title}
            </h3>
          </div>

          {/* Description */}
          <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
            {svc.desc}
          </p>

          {/* Mini-bullets */}
          <ul class="mt-2.5 space-y-1 pl-4 text-xs leading-relaxed text-muted-foreground/70">
            {svc.bullets.map((b) => (
              <li class="list-disc">{b}</li>
            ))}
          </ul>

        </div>
      ))}
    </div>
  </Container>
</Section>
