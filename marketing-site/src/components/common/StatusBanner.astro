---
interface Props {
  class?: string;
  message?: string;
}

const {
  class: className,
  message = "After-hours coverage 24/7",
} = Astro.props;
---

<div
  class:list={[
    "flex items-center justify-center gap-2 bg-primary px-4 py-2 text-sm font-medium text-primary-foreground",
    className,
  ]}
>
  <span class="relative flex h-2 w-2">
    <span
      class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary-foreground/75"
    ></span>
    <span class="relative inline-flex h-2 w-2 rounded-full bg-primary-foreground"
    ></span>
  </span>
  {message}
</div>
