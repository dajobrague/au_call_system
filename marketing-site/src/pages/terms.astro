---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/layout/Container.astro";
import Section from "@/components/layout/Section.astro";
import H1 from "@/components/typography/H1.astro";
import Lead from "@/components/typography/Lead.astro";
---

<BaseLayout title="Terms of Service">
  <Section>
    <Container>
      <div class="mx-auto max-w-3xl">
        <H1>Terms of Service</H1>
        <Lead class="mt-4">
          This page will contain the OnCallAfterHours terms of service. Content
          will be added in a follow-up update.
        </Lead>
        <div class="mt-8 rounded-lg border border-border bg-muted/30 p-8 text-center">
          <p class="text-muted-foreground">Terms of service content placeholder.</p>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>
