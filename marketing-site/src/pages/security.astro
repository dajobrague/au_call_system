---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";
import { buttonVariants } from "@/components/ui/button";
---

<BaseLayout title="Security — On Call After Hours">

  {/* ═══ HERO ═══ */}
  <Section padding="lg" animate={false} class="relative overflow-hidden">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/[0.03] blur-[100px]" aria-hidden="true"></div>
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <div class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10">
          <svg class="h-7 w-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path>
          </svg>
        </div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">
          Security
        </p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Designed for secure, accountable after-hours operations
        </h1>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
          On Call After Hours is built for providers that need encrypted communications, controlled access, auditable records, and Australian-hosted infrastructure — all managed from your own dashboard.
        </p>
        <p class="mt-3 text-sm text-muted-foreground/60">
          Every layer of the platform is designed with healthcare operational requirements in mind.
        </p>
      </div>
    </Container>
  </Section>

  {/* ═══ SECURITY PILLARS — 4 Cards ═══ */}
  <Section padding="md" class="bg-muted/20">
    <Container>
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {/* Pillar 1 — Encryption in transit */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-foreground">Encrypted data in transit</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">All connections are encrypted via TLS. API endpoints, dashboard access, and voice data are secured end-to-end between your team and the platform.</p>
        </div>

        {/* Pillar 2 — Australian infrastructure */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-foreground">Australian-hosted infrastructure</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Platform infrastructure is hosted in Australia, supporting data sovereignty requirements and keeping operational records within local jurisdiction.</p>
        </div>

        {/* Pillar 3 — Role-based access */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4-4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-foreground">Role-based access control</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Assign Admin, Manager, or Viewer roles to team members. Each role has scoped permissions controlling what they can view, configure, and export.</p>
        </div>

        {/* Pillar 4 — Audit trail */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M12 18v-6"></path><path d="m9 15 3 3 3-3"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-sm font-semibold text-foreground">Full audit trail</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Every action is logged with timestamps, user identity, and event type. Settings changes, logins, report downloads, and escalation actions are all recorded.</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* ═══ CALL RECORDING SECURITY ═══ */}
  <Section padding="md">
    <Container>
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-primary/70">
            Recording Security
          </p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
            Secure call recording storage
          </h2>
          <p class="mt-3 text-base leading-relaxed text-muted-foreground">
            After-hours call recordings are stored securely with access restrictions, so only authorised team members can review them. Recordings are retained in line with provider-configured policies.
          </p>
          <ul class="mt-5 space-y-2.5">
            {["Recordings stored in encrypted, access-controlled storage", "Playback restricted to authorised roles only", "Retention periods aligned with provider requirements", "Access events logged in the audit trail"].map((b) => (
              <li class="flex items-start gap-2.5">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
                <span class="text-sm text-foreground/80">{b}</span>
              </li>
            ))}
          </ul>
        </div>

        {/* Mockup: Recording access panel */}
        <div class="rounded-xl border border-border/60 bg-card shadow-lg overflow-hidden">
          <div class="flex items-center justify-between bg-foreground/[0.03] border-b border-border/40 px-4 py-2.5">
            <div class="flex items-center gap-2">
              <svg class="h-3.5 w-3.5 text-muted-foreground/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
              </svg>
              <span class="text-[11px] font-semibold text-foreground">Call Recordings</span>
            </div>
            <span class="text-[10px] text-muted-foreground/50">Secure Storage</span>
          </div>
          <div class="p-4 sm:p-5 space-y-3">
            {/* Recording row 1 */}
            <div class="rounded-lg border border-border/40 bg-muted/20 p-3">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2">
                  <div class="h-6 w-6 rounded-full bg-primary/10 flex items-center justify-center text-[9px] font-bold text-primary">MW</div>
                  <div>
                    <div class="text-[11px] font-medium text-foreground">Margaret Wilson — Sick call</div>
                    <div class="text-[9px] text-muted-foreground/60">25 Feb, 11:42 PM · 3m 18s</div>
                  </div>
                </div>
                <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2 py-0.5 text-[9px] font-medium text-emerald-700 ring-1 ring-emerald-200/60">
                  <svg class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                  Encrypted
                </span>
              </div>
              <div class="flex items-center gap-2">
                <button class="inline-flex items-center gap-1 rounded-md bg-card border border-border/40 px-2.5 py-1 text-[10px] font-medium text-foreground/70 cursor-default">
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                  Play
                </button>
                <button class="inline-flex items-center gap-1 rounded-md bg-card border border-border/40 px-2.5 py-1 text-[10px] font-medium text-foreground/70 cursor-default">
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>
                  Download
                </button>
                <span class="ml-auto text-[9px] text-muted-foreground/50">Requires Admin role</span>
              </div>
            </div>

            {/* Recording row 2 */}
            <div class="rounded-lg border border-border/40 bg-muted/20 p-3">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-2">
                  <div class="h-6 w-6 rounded-full bg-amber-100 flex items-center justify-center text-[9px] font-bold text-amber-700">DL</div>
                  <div>
                    <div class="text-[11px] font-medium text-foreground">David Lee — Patient concern</div>
                    <div class="text-[9px] text-muted-foreground/60">25 Feb, 1:07 AM · 5m 42s</div>
                  </div>
                </div>
                <span class="inline-flex items-center gap-1 rounded-full bg-emerald-50 px-2 py-0.5 text-[9px] font-medium text-emerald-700 ring-1 ring-emerald-200/60">
                  <svg class="h-2.5 w-2.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                  Encrypted
                </span>
              </div>
            </div>

            {/* Access log */}
            <div class="border-t border-border/40 pt-3">
              <div class="text-[9px] font-medium uppercase tracking-wider text-muted-foreground/50 mb-2">Recent Access Log</div>
              <div class="space-y-1">
                <div class="flex items-center justify-between text-[10px]">
                  <span class="text-foreground/70">Sarah M. played recording</span>
                  <span class="text-muted-foreground/50 tabular-nums">9:14 AM</span>
                </div>
                <div class="flex items-center justify-between text-[10px]">
                  <span class="text-foreground/70">Sarah M. downloaded recording</span>
                  <span class="text-muted-foreground/50 tabular-nums">9:15 AM</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  {/* ═══ BACKUPS & DISASTER RECOVERY ═══ */}
  <Section padding="md" class="bg-muted/20">
    <Container>
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
        {/* Mockup left */}
        <div class="order-2 lg:order-1">
          <div class="rounded-xl border border-border/60 bg-card shadow-lg overflow-hidden">
            <div class="flex items-center justify-between bg-foreground/[0.03] border-b border-border/40 px-4 py-2.5">
              <div class="flex items-center gap-2">
                <svg class="h-3.5 w-3.5 text-muted-foreground/60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
                <span class="text-[11px] font-semibold text-foreground">Infrastructure Status</span>
              </div>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-50 px-2 py-0.5 text-[10px] font-medium text-emerald-700 ring-1 ring-emerald-200/60">
                <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                All systems healthy
              </span>
            </div>
            <div class="p-4 sm:p-5 space-y-3">
              {/* Backup status */}
              <div class="rounded-lg border border-border/40 p-3">
                <div class="flex items-center justify-between mb-3">
                  <span class="text-[11px] font-semibold text-foreground">Backup Schedule</span>
                  <span class="text-[10px] text-emerald-600 font-medium">Automated</span>
                </div>
                <div class="space-y-2">
                  <div class="flex items-center justify-between">
                    <span class="text-[11px] text-foreground/70">Last full backup</span>
                    <span class="rounded-full bg-muted px-2 py-0.5 text-[10px] font-medium text-foreground/70 tabular-nums">Today, 3:00 AM</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-[11px] text-foreground/70">Last incremental</span>
                    <span class="rounded-full bg-muted px-2 py-0.5 text-[10px] font-medium text-foreground/70 tabular-nums">Today, 7:00 AM</span>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-[11px] text-foreground/70">Backup frequency</span>
                    <span class="rounded-full bg-muted px-2 py-0.5 text-[10px] font-medium text-foreground/70">Daily full + 4-hourly incremental</span>
                  </div>
                </div>
              </div>

              {/* Recovery metrics */}
              <div class="grid grid-cols-2 gap-3">
                <div class="rounded-lg border border-border/40 p-3 text-center">
                  <div class="text-[9px] font-medium uppercase tracking-wider text-muted-foreground/50 mb-1">Recovery Point</div>
                  <div class="text-lg font-bold text-foreground tabular-nums">4 hrs</div>
                  <div class="text-[9px] text-muted-foreground/50">Max data window</div>
                </div>
                <div class="rounded-lg border border-border/40 p-3 text-center">
                  <div class="text-[9px] font-medium uppercase tracking-wider text-muted-foreground/50 mb-1">Redundancy</div>
                  <div class="text-lg font-bold text-foreground">Multi-AZ</div>
                  <div class="text-[9px] text-muted-foreground/50">Availability zones</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Text right */}
        <div class="order-1 lg:order-2">
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-primary/70">
            Reliability
          </p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
            Backups and disaster recovery
          </h2>
          <p class="mt-3 text-base leading-relaxed text-muted-foreground">
            On Call After Hours runs on infrastructure designed for resilience. Regular automated backups and redundant hosting reduce the risk of data loss and help maintain service availability.
          </p>
          <ul class="mt-5 space-y-2.5">
            {["Daily full backups with 4-hourly incremental snapshots", "Infrastructure hosted across multiple availability zones", "Recovery procedures tested and documented", "Automated monitoring with alerting for infrastructure health"].map((b) => (
              <li class="flex items-start gap-2.5">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
                <span class="text-sm text-foreground/80">{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Container>
  </Section>

  {/* ═══ NDIS PRACTICE STANDARDS ALIGNMENT ═══ */}
  <Section padding="md">
    <Container>
      <div class="mx-auto max-w-3xl text-center mb-10">
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-primary/70">
          Standards Alignment
        </p>
        <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
          Designed with NDIS Practice Standards in mind
        </h2>
        <p class="mt-3 text-base leading-relaxed text-muted-foreground">
          On Call After Hours is built to support providers in meeting their obligations under the NDIS Practice Standards. The platform's design choices reflect key areas of these standards.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {/* Standard 1 — Governance */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-3">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="16" height="20" x="4" y="2" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path><path d="M12 10h.01"></path><path d="M12 14h.01"></path><path d="M16 10h.01"></path><path d="M16 14h.01"></path><path d="M8 10h.01"></path><path d="M8 14h.01"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground">Governance and Operational Management</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Provider-controlled settings, role-based access, and structured workflows give organisations governance over their after-hours operations.</p>
        </div>

        {/* Standard 2 — Information Management */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-3">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 17a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3.9a2 2 0 0 1-1.69-.9l-.81-1.2a2 2 0 0 0-1.67-.9H8a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2Z"></path><path d="M2 8v11a2 2 0 0 0 2 2h14"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground">Information Management</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Encrypted storage, Australian hosting, access-controlled records, and downloadable reports support secure and organised information handling.</p>
        </div>

        {/* Standard 3 — Incident Management */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-3">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground">Incident Management</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">After-hours events are captured, logged, and escalated through structured workflows, creating a documented trail for incident review and reporting.</p>
        </div>

        {/* Standard 4 — Human Resource Management */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-3">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4-4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M22 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground">Human Resource Management</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Schedule-based workflows and sick call handling support staff management processes overnight, with records available for review the next morning.</p>
        </div>

        {/* Standard 5 — Continuity of Supports */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-3">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground">Continuity of Supports</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Automated call answering and escalation ensure after-hours issues are captured and acted on, reducing the risk of missed or delayed responses.</p>
        </div>

        {/* Standard 6 — Risk Management */}
        <div class="rounded-xl border border-border/60 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-3">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path>
            </svg>
          </div>
          <h3 class="text-sm font-semibold text-foreground">Risk Management</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Audit logging, backup procedures, encrypted storage, and live monitoring help providers maintain a stronger risk management posture for overnight operations.</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* ═══ ROLE-BASED ACCESS DEEP DIVE ═══ */}
  <Section padding="md" class="bg-muted/20">
    <Container>
      <div class="grid grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
        <div>
          <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-primary/70">
            Access Control
          </p>
          <h2 class="mt-2 text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
            Scoped permissions for every team member
          </h2>
