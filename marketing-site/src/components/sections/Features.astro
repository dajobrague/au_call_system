---
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";
---

<Section padding="lg" variant="tinted">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">
        Features
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Built for real care operations
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2">
      {/* ── Card 1: Live operations window ── */}
      <div class="group rounded-xl border border-border/60 bg-card overflow-hidden shadow-sm transition-shadow duration-200 hover:shadow-md">
        <div class="p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-foreground">Live operations window</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">See active overnight events, statuses, and actions as they happen.</p>
        </div>
        {/* Mini mockup: event feed */}
        <div class="border-t border-border/40 bg-muted/20 px-6 py-4">
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-green-500 shrink-0"></span>
              <span class="text-[11px] text-foreground/60">Incoming call — triaged</span>
              <span class="ml-auto text-[10px] text-muted-foreground/50">11:42 pm</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-amber-500 shrink-0"></span>
              <span class="text-[11px] text-foreground/60">Escalation — awaiting response</span>
              <span class="ml-auto text-[10px] text-muted-foreground/50">11:38 pm</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-green-500 shrink-0"></span>
              <span class="text-[11px] text-foreground/60">Sick call — shift covered</span>
              <span class="ml-auto text-[10px] text-muted-foreground/50">11:15 pm</span>
            </div>
          </div>
        </div>
      </div>

      {/* ── Card 2: Provider-controlled settings ── */}
      <div class="group rounded-xl border border-border/60 bg-card overflow-hidden shadow-sm transition-shadow duration-200 hover:shadow-md">
        <div class="p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-foreground">Provider-controlled settings</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Manage transfer numbers, escalation paths, on-call windows, and workflow preferences.</p>
        </div>
        {/* Mini mockup: settings rows */}
        <div class="border-t border-border/40 bg-muted/20 px-6 py-4">
          <div class="space-y-2.5">
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-foreground/60">Transfer number</span>
              <span class="rounded-full bg-card border border-border/60 px-2.5 py-0.5 text-[10px] font-medium text-foreground/70">+61 4XX XXX XXX</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-foreground/60">On-call window</span>
              <span class="rounded-full bg-card border border-border/60 px-2.5 py-0.5 text-[10px] font-medium text-foreground/70">6 pm – 8 am</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-foreground/60">Outbound attempts</span>
              <span class="rounded-full bg-card border border-border/60 px-2.5 py-0.5 text-[10px] font-medium text-foreground/70">3 max</span>
            </div>
          </div>
        </div>
      </div>

      {/* ── Card 3: Transfer to human ── */}
      <div class="group rounded-xl border border-border/60 bg-card overflow-hidden shadow-sm transition-shadow duration-200 hover:shadow-md">
        <div class="p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="18 2 22 6 18 10"></polyline><line x1="14" x2="22" y1="6" y2="6"></line>
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-foreground">Transfer to human</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Move a call to a nominated contact at any point when needed.</p>
        </div>
        {/* Mini mockup: transfer action */}
        <div class="border-t border-border/40 bg-muted/20 px-6 py-4">
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10">
              <svg class="h-3.5 w-3.5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-[11px] font-medium text-foreground/70 truncate">On-call coordinator</p>
              <p class="text-[10px] text-muted-foreground/60">Transferring...</p>
            </div>
            <div class="flex h-6 items-center rounded-full bg-green-500/10 px-2.5">
              <span class="text-[10px] font-medium text-green-600">Connected</span>
            </div>
          </div>
        </div>
      </div>

      {/* ── Card 4: Morning reports ── */}
      <div class="group rounded-xl border border-border/60 bg-card overflow-hidden shadow-sm transition-shadow duration-200 hover:shadow-md">
        <div class="p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"></path><path d="M16 17H8"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-foreground">Morning reports</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Download clear overnight reports, logs, and event summaries.</p>
        </div>
        {/* Mini mockup: report summary */}
        <div class="border-t border-border/40 bg-muted/20 px-6 py-4">
          <div class="space-y-2">
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-foreground/60">Total calls</span>
              <span class="text-[11px] font-semibold text-foreground/80">12</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-foreground/60">Escalations</span>
              <span class="text-[11px] font-semibold text-foreground/80">3</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-[11px] text-foreground/60">Report status</span>
              <span class="inline-flex items-center gap-1 text-[10px] font-medium text-green-600">
                <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>Ready
              </span>
            </div>
          </div>
        </div>
      </div>

      {/* ── Card 5: Schedule-ready workflows ── */}
      <div class="group rounded-xl border border-border/60 bg-card overflow-hidden shadow-sm transition-shadow duration-200 hover:shadow-md">
        <div class="p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 2v4"></path><path d="M16 2v4"></path><rect width="18" height="18" x="3" y="4" rx="2"></rect><path d="M3 10h18"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-foreground">Schedule-ready workflows</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Upload your evening roster so the platform handles overnight calls with the right context.</p>
        </div>
        {/* Mini mockup: roster preview */}
        <div class="border-t border-border/40 bg-muted/20 px-6 py-4">
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <div class="h-5 w-5 rounded-full bg-blue-100 flex items-center justify-center"><span class="text-[9px] font-bold text-blue-600">JL</span></div>
              <span class="text-[11px] text-foreground/60 flex-1">J. Lawson</span>
              <span class="text-[10px] text-muted-foreground/50">6 pm – 2 am</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="h-5 w-5 rounded-full bg-purple-100 flex items-center justify-center"><span class="text-[9px] font-bold text-purple-600">MK</span></div>
              <span class="text-[11px] text-foreground/60 flex-1">M. Kim</span>
              <span class="text-[10px] text-muted-foreground/50">2 am – 8 am</span>
            </div>
          </div>
        </div>
      </div>

      {/* ── Card 6: Australian-hosted records ── */}
      <div class="group rounded-xl border border-border/60 bg-card overflow-hidden shadow-sm transition-shadow duration-200 hover:shadow-md">
        <div class="p-6">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
            <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path>
            </svg>
          </div>
          <h3 class="mt-4 text-base font-semibold text-foreground">Australian-hosted records</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">Records stored on Australian infrastructure for data sovereignty and operational traceability.</p>
        </div>
        {/* Mini mockup: security summary */}
        <div class="border-t border-border/40 bg-muted/20 px-6 py-4">
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <svg class="h-3 w-3 text-green-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span class="text-[11px] text-foreground/60">TLS encryption active</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-3 w-3 text-green-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span class="text-[11px] text-foreground/60">AU-East data region</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="h-3 w-3 text-green-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>
              <span class="text-[11px] text-foreground/60">Role-based access control</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-8 text-center">
      <a
        href="/features"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline"
      >
        View all features <span>&rarr;</span>
      </a>
    </div>
  </Container>
</Section>
