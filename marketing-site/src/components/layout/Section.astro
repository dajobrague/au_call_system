---
interface Props {
  class?: string;
  id?: string;
  padding?: "none" | "sm" | "md" | "lg";
  variant?: "default" | "tinted";
  animate?: boolean;
}

const { class: className, id, padding = "lg", variant = "default", animate = true } = Astro.props;

const paddingMap = {
  none: "",
  sm: "py-8 sm:py-12",
  md: "py-12 sm:py-16",
  lg: "py-16 sm:py-24",
};
---

<section
  id={id}
  class:list={[
    paddingMap[padding],
    variant === "tinted" && "section-tinted",
    animate && "fade-up",
    className,
  ]}
>
  {variant === "tinted" && (
    <div
      class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/[0.04] blur-[100px]"
      aria-hidden="true"
    ></div>
  )}

  <slot />
</section>

<style>
  .section-tinted {
    position: relative;
    overflow: hidden;
    background: color-mix(in srgb, hsl(var(--primary)) 3%, hsl(var(--background)));
  }

  .section-tinted::before,
  .section-tinted::after {
    content: "";
    position: absolute;
    left: -5%;
    right: -5%;
    height: 40px;
    background: hsl(var(--background));
    pointer-events: none;
    z-index: 1;
  }

  @media (min-width: 640px) {
    .section-tinted::before,
    .section-tinted::after {
      height: 60px;
    }
  }

  .section-tinted::before {
    top: -1px;
    border-radius: 0 0 50% 50%;
  }

  .section-tinted::after {
    bottom: -1px;
    border-radius: 50% 50% 0 0;
  }
</style>
