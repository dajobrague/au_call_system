---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";

const nextSteps = [
  "We review your organisation's workflow needs",
  "We walk you through the platform live",
  "We recommend the best pricing tier",
  "We answer questions about fit and configuration",
];
---

<BaseLayout title="Book a Demo — On Call After Hours">

  {/* Hero */}
  <Section padding="lg" animate={false} class="relative overflow-hidden">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[500px] w-[500px] rounded-full bg-primary/[0.03] blur-[100px]" aria-hidden="true"></div>
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">
          Book a demo
        </p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          See how On Call After Hours could fit your after-hours workflow
        </h1>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
          Tell us a little about your organisation and we'll walk you through the platform, pricing, and fit.
        </p>
      </div>
    </Container>
  </Section>

  {/* Form */}
  <Section padding="lg" variant="tinted">
    <Container>
      <div class="mx-auto max-w-2xl">
        <form id="contact-form" class="space-y-5">
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="firstName" class="block text-sm font-medium text-foreground">First name</label>
              <input
                type="text"
                id="firstName"
                name="firstName"
                required
                class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="First name"
              />
            </div>
            <div>
              <label for="lastName" class="block text-sm font-medium text-foreground">Last name</label>
              <input
                type="text"
                id="lastName"
                name="lastName"
                required
                class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="Last name"
              />
            </div>
          </div>

          <div>
            <label for="organisation" class="block text-sm font-medium text-foreground">Organisation</label>
            <input
              type="text"
              id="organisation"
              name="organisation"
              required
              class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              placeholder="Your organisation name"
            />
          </div>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="email" class="block text-sm font-medium text-foreground">Work email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="you@company.com"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-foreground">Phone number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
                placeholder="+61 400 000 000"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <label for="providerType" class="block text-sm font-medium text-foreground">Provider type</label>
              <select
                id="providerType"
                name="providerType"
                class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              >
                <option value="">Select type</option>
                <option value="ndis">NDIS Provider</option>
                <option value="home-care">Home Care Provider</option>
                <option value="disability">Disability Services</option>
                <option value="aged-care">Aged Care</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label for="locations" class="block text-sm font-medium text-foreground">Number of locations / houses</label>
              <select
                id="locations"
                name="locations"
                class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              >
                <option value="">Select range</option>
                <option value="1-5">1 – 5</option>
                <option value="6-15">6 – 15</option>
                <option value="16-30">16 – 30</option>
                <option value="31+">31+</option>
              </select>
            </div>
          </div>

          <div>
            <label for="volume" class="block text-sm font-medium text-foreground">Approximate after-hours call volume</label>
            <select
              id="volume"
              name="volume"
              class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            >
              <option value="">Select volume</option>
              <option value="low">Low (a few per week)</option>
              <option value="moderate">Moderate (daily)</option>
              <option value="high">High (multiple daily)</option>
              <option value="very-high">Very high (constant overnight)</option>
            </select>
          </div>

          <div>
            <label for="currentProcess" class="block text-sm font-medium text-foreground">Current after-hours process</label>
            <textarea
              id="currentProcess"
              name="currentProcess"
              rows="2"
              class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-none"
              placeholder="How do you currently handle after-hours calls?"
            ></textarea>
          </div>

          <div>
            <label for="challenge" class="block text-sm font-medium text-foreground">Biggest challenge</label>
            <textarea
              id="challenge"
              name="challenge"
              rows="2"
              class="mt-1.5 block w-full rounded-lg border border-input bg-card px-3.5 py-2.5 text-sm text-foreground shadow-sm transition-colors placeholder:text-muted-foreground/50 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-none"
              placeholder="What is your biggest after-hours challenge?"
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex h-12 w-full items-center justify-center rounded-lg bg-primary px-8 text-sm font-semibold text-primary-foreground shadow-sm transition-all duration-200 hover:bg-primary/90 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 sm:w-auto"
          >
            Request Demo
            <svg class="ml-2 h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
            </svg>
          </button>
        </form>

        <div id="form-success" class="hidden rounded-xl border border-emerald-200 bg-emerald-50 p-6 text-center">
          <svg class="mx-auto h-10 w-10 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5"></path>
          </svg>
          <h3 class="mt-3 text-lg font-semibold text-emerald-900">Demo request received</h3>
          <p class="mt-1 text-sm text-emerald-700">We'll be in touch shortly to schedule your walkthrough.</p>
        </div>
      </div>
    </Container>
  </Section>

  {/* What happens next */}
  <Section padding="lg">
    <Container>
      <div class="grid grid-cols-1 items-start gap-12 lg:grid-cols-2 lg:gap-16">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
            What happens next
          </h2>
          <ul class="mt-6 space-y-4">
            {nextSteps.map((step, i) => (
              <li class="flex items-start gap-3">
                <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-bold text-primary">
                  {i + 1}
                </div>
                <span class="pt-0.5 text-sm text-foreground/80">{step}</span>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
            Prefer to contact us directly?
          </h2>
          <div class="mt-6 space-y-4">
            <div class="flex items-center gap-3">
              <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
              <a href="mailto:hello@oncallafterhours.com.au" class="text-sm font-medium text-foreground hover:text-primary transition-colors">
                hello@oncallafterhours.com.au
              </a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="h-5 w-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path><circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span class="text-sm text-muted-foreground">Australia</span>
            </div>
          </div>
        </div>
      </div>
    </Container>
  </Section>

</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.classList.add('hidden');
      success.classList.remove('hidden');
    });
  }
</script>
