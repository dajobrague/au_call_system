---
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";

const testimonials = [
  {
    quote: "We used to spend the first hour of every morning piecing together what happened overnight. Now the report is waiting when we arrive.",
    name: "Sarah M.",
    title: "Operations Manager",
    org: "CareBridge NDIS Services",
  },
  {
    quote: "The live dashboard gives us visibility we never had before. Our on-call coordinator can see exactly what's happening without being on the phone.",
    name: "James T.",
    title: "Service Director",
    org: "BrightPath Home Care",
  },
  {
    quote: "Onboarding was straightforward and the provider controls mean we can adjust workflows ourselves without waiting on support.",
    name: "Linda K.",
    title: "Care Coordinator",
    org: "Nexus Disability Support",
  },
];
---

<Section padding="lg">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">
        Testimonials
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Trusted by care providers across Australia
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="flex flex-col rounded-xl border border-border/60 bg-card p-6 shadow-sm">
          {/* Quote icon */}
          <svg class="mb-4 h-6 w-6 text-primary/30" viewBox="0 0 24 24" fill="currentColor">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"></path>
          </svg>
          <p class="flex-1 text-sm leading-relaxed text-foreground/80">{t.quote}</p>
          <div class="mt-5 flex items-center gap-3 border-t border-border/40 pt-4">
            <div class="flex h-9 w-9 items-center justify-center rounded-full bg-primary/10 text-xs font-bold text-primary">
              {t.name.split(" ").map((n) => n[0]).join("")}
            </div>
            <div>
              <p class="text-sm font-semibold text-foreground">{t.name}</p>
              <p class="text-xs text-muted-foreground">{t.title}, {t.org}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </Container>
</Section>
