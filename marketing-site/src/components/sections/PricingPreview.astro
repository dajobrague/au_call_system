---
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";
import { buttonVariants } from "@/components/ui/button";

const plans = [
  {
    name: "Starter",
    price: "$249",
    desc: "Best for smaller providers trialling after-hours automation.",
    features: [
      "120 inbound voice minutes",
      "25 outbound call attempts",
      "100 SMS",
      "Self-serve onboarding",
      "Live dashboard",
      "Downloadable morning reports",
    ],
  },
  {
    name: "Growth",
    price: "$449",
    desc: "Best for providers with more regular after-hours activity.",
    popular: true,
    features: [
      "300 inbound voice minutes",
      "60 outbound call attempts",
      "250 SMS",
      "Everything in Starter",
      "Multi-location configuration",
      "Expanded controls",
    ],
  },
  {
    name: "Pro",
    price: "$749",
    desc: "Best for providers with heavier overnight volume.",
    features: [
      "700 inbound voice minutes",
      "140 outbound call attempts",
      "600 SMS",
      "Everything in Growth",
      "Advanced workflow settings",
      "Expanded reporting",
    ],
  },
];
---

<Section padding="lg" variant="tinted">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">
        Pricing
      </p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Simple monthly pricing with included usage
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground">
        Choose a plan based on your overnight volume. Every plan includes self-serve onboarding, dashboard access, and monthly allowances.
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {plans.map((plan) => (
        <div class:list={[
          "relative flex flex-col rounded-xl border bg-card p-6 shadow-sm transition-shadow duration-200 hover:shadow-md",
          plan.popular ? "border-primary/30 ring-1 ring-primary/20" : "border-border/60",
        ]}>
          {plan.popular && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="rounded-full bg-primary px-3 py-0.5 text-[10px] font-semibold text-primary-foreground">
                Most popular
              </span>
            </div>
          )}
          <div>
            <h3 class="text-lg font-semibold text-foreground">{plan.name}</h3>
            <div class="mt-2 flex items-baseline gap-1">
              <span class="text-3xl font-bold tracking-tight text-foreground">{plan.price}</span>
              <span class="text-sm text-muted-foreground">/month</span>
            </div>
            <p class="mt-2 text-sm text-muted-foreground">{plan.desc}</p>
          </div>
          <ul class="mt-6 flex-1 space-y-2.5">
            {plan.features.map((f) => (
              <li class="flex items-start gap-2">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 6 9 17l-5-5"></path>
                </svg>
                <span class="text-sm text-foreground/80">{f}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6">
            <a
              href="/contact"
              class:list={[
                buttonVariants({ variant: plan.popular ? "default" : "outline", size: "default" }),
                "w-full justify-center",
              ]}
            >
              Book a Demo
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a href="/pricing" class="text-sm font-medium text-primary underline-offset-4 hover:underline">
        View full pricing details &rarr;
      </a>
      <p class="mt-2 text-xs text-muted-foreground">No onboarding fee. Extra usage billed separately.</p>
    </div>
  </Container>
</Section>
