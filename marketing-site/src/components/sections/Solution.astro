---
import Section from "@/components/layout/Section.astro";
import Container from "@/components/layout/Container.astro";

const bullets = [
  "After-hours calls are answered and triaged automatically",
  "Issues are captured and routed into the right workflow",
  "Escalation follows your own provider settings",
  "Managers can monitor live activity overnight",
  "Calls can be transferred to a human when needed",
  "Reports are ready by morning",
];

const steps = [
  { num: "1", label: "Call received" },
  { num: "2", label: "Issue captured" },
  { num: "3", label: "Workflow applied" },
  { num: "4", label: "Escalation started" },
  { num: "5", label: "Report generated" },
];
---

<Section padding="lg" variant="tinted">
  <Container>
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div>
        <p class="text-[11px] font-semibold uppercase tracking-[0.12em] text-muted-foreground/70">
          The solution
        </p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Upload your schedule. Configure your rules. Let On Call After Hours handle the rest.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">
          On Call After Hours answers after-hours calls, captures the issue, applies your configured workflow, starts escalation, and gives your team live visibility throughout the night. By morning, your reports and logs are ready to review and download.
        </p>
        <ul class="mt-6 space-y-3">
          {bullets.map((b) => (
            <li class="flex items-start gap-2.5">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"></path>
              </svg>
              <span class="text-sm text-foreground/80">{b}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="relative">
        <div class="rounded-xl border border-border/60 bg-card p-6 shadow-sm sm:p-8">
          <div class="space-y-0">
            {steps.map((step, i) => (
              <div class="relative flex items-start gap-4 pb-8 last:pb-0">
                {i < steps.length - 1 && (
                  <div class="absolute left-[15px] top-8 h-full w-px bg-border/60" aria-hidden="true"></div>
                )}
                <div class="relative z-10 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-xs font-bold text-primary-foreground">
                  {step.num}
                </div>
                <div class="pt-1">
                  <p class="text-sm font-semibold text-foreground">{step.label}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Container>
</Section>
